      "id": "levelup",
      "op": "label"
    },
    {
      "id": "__loop16",
      "op": "label"
    },
    {
      "else": "__end16",
      "expr": "xp \u003e= need",
      "op": "if",
      "then": "__body16"
    },
    {
      "id": "__body16",
      "op": "label"
    },
    {
      "expr": "xp - need",
      "key": "xp",
      "op": "set"
    },
    {
      "expr": "level + 1",
      "key": "level",
      "op": "set"
    },
    {
      "expr": "maxhp + 6",
      "key": "maxhp",
      "op": "set"
    },
    {
      "expr": "maxhp",
      "key": "hp",
      "op": "set"
    },
    {
      "expr": "atk + 2",
      "key": "atk",
      "op": "set"
    },
    {
      "expr": "def + 1",
      "key": "def",
      "op": "set"
    },
    {
      "expr": "floor(need * 1.5)",
      "key": "need",
      "op": "set"
    },
    {
      "op": "say",
      "text": "✨ Новый уровень — {level}! Здоровье и сила возросли."
    },
    {
      "label": "__loop16",
      "op": "goto"
    },
    {
      "id": "__end16",
      "op": "label"
    },
    {
      "op": "return"
    },
