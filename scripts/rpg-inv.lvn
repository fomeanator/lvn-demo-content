    {
      "op": "say",
      "text": "Холодное утро. Ты — безвестный странник на тропе к деревне Двуречье. Говорят, в пещере за околицей пробудился орк-вожак, и староста сулит золото смельчаку."
    },
    {
      "label": "__fn_show_hero",
      "op": "call"
    },
    {
      "label": "village",
      "op": "goto"
    },
    {
      "id": "village",
      "op": "label"
    },
    {
      "id": "Clearing_in_forest",
      "op": "bg",
      "sprite_url": "/content/bg/Clearing_in_forest.jpg"
    },
    {
      "op": "say",
      "text": "Площадь Двуречья. Куда направишься?"
    },
    {
      "op": "choice",
      "options": [
        {
          "goto": "tavern",
          "text": "В таверну (слухи, отдых)"
        },
        {
          "goto": "smith",
          "text": "К кузнецу (оружие, броня)"
        },
        {
          "goto": "merchant",
          "text": "К торговцу (зелья, факел, продажа)"
        },
        {
          "goto": "forest",
          "text": "В лес (охота, добыча)"
        },
        {
          "goto": "cave_gate",
          "text": "К пещере орка"
        },
        {
          "goto": "mirror",
          "text": "К зеркалу у колодца (гардероб)"
        }
      ]
    },
    {
      "id": "mirror",
      "op": "label"
    },
    {
      "op": "say",
      "text": "Гладь старого зеркала отражает тебя в полный рост."
