    {
      "id": "fight",
      "op": "label"
    },
    {
      "op": "say",
      "text": "{ename} перед тобой — ♥{ehp}. Твой ход."
    },
    {
      "op": "choice",
      "options": [
        {
          "goto": "f_atk",
          "text": "Атаковать ({wname})"
        },
        {
          "goto": "f_heavy",
          "text": "Сильный удар (риск промаха)"
        },
        {
          "goto": "f_potion",
          "text": "Выпить зелье"
        },
        {
          "goto": "f_defend",
          "text": "Защита"
        },
        {
          "goto": "f_flee",
          "text": "Бежать"
        }
      ]
    },
    {
      "id": "f_atk",
      "op": "label"
    },
    {
      "expr": "max(1, atk + watk - edef + rand(0,3))",
      "key": "pdmg",
      "op": "set"
    },
    {
      "expr": "ehp - pdmg",
      "key": "ehp",
      "op": "set"
    },
    {
      "op": "say",
      "text": "Ты наносишь {pdmg} урона."
    },
    {
      "else": "__nf6",
      "expr": "ehp \u003c= 0",
      "op": "if",
      "then": "f_win"
    },
    {
      "id": "__nf6",
      "op": "label"
    },
    {
      "label": "f_enemy",
      "op": "goto"
    },
    {
      "id": "f_heavy",
      "op": "label"
    },
    {
      "else": "__else12",
      "expr": "chance(0.7)",
      "op": "if",
      "then": "__then12"
    },
    {
      "id": "__then12",
      "op": "label"
    },
    {
      "expr": "max(1, (atk + watk) * 2 - edef + rand(0,2))",
      "key": "pdmg",
      "op": "set"
    },
    {
      "expr": "ehp - pdmg",
      "key": "ehp",
      "op": "set"
    },
    {
      "op": "say",
      "text": "Размашистый удар! {pdmg} урона."
