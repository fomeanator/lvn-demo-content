      "key": "Wardrobe.mainCh_Clothes",
      "op": "set",
      "value": 11
    },
    {
      "op": "say",
      "text": "Ну точно! Надо же им просто позвонить!",
      "who": "Главный герой"
    },
    {
      "label": "__end",
      "op": "goto"
    },
    {
      "id": "n45_000000",
      "op": "label"
    },
    {
      "op": "say",
      "text": "Сцена 16. Дорога без жигулей",
