    },
    {
      "op": "choice",
      "options": [
        {
          "goto": "n30_000000",
          "text": "Подруга выбирается из автомобиля, потягива�"
        },
        {
          "goto": "n31_000000",
          "text": "Сцена 10. Пещера"
